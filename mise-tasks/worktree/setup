#!/usr/bin/env bash
#MISE description="Pin gh to origin; on linked worktrees also mise install + lefthook"

set -euo pipefail

root=$(git rev-parse --show-toplevel)
# shellcheck source=../_lib/gh-origin.sh
source "${root}/mise-tasks/_lib/gh-origin.sh"

# Always: gh CLI must talk to the fork (origin), not upstream parent.
ensure_gh_default_origin

# Linked worktrees have .git as a file; primary checkout is a directory.
# Skip heavy install on ordinary branch switches in the main tree.
if [[ -d .git ]] && [[ "${MISE_WORKTREE_FORCE:-}" != "1" ]]; then
  exit 0
fi

mise install --quiet
lefthook install
