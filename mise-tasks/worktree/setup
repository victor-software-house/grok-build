#!/usr/bin/env bash
#MISE description="Install tools + lefthook (no-op on primary checkout for post-checkout)"

set -euo pipefail

# Linked worktrees have .git as a file; primary checkout is a directory.
# post-checkout should not reinstall hooks on every branch switch in the main tree.
if [[ -d .git ]] && [[ "${MISE_WORKTREE_FORCE:-}" != "1" ]]; then
  exit 0
fi

mise install --quiet
lefthook install
