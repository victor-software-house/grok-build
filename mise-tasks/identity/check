#!/usr/bin/env bash
#MISE description="Fail if our commits' author/committer emails are outside commit-email-allowlist"
#MISE alias="id-check"
#USAGE arg "[range]" help="git range (default: unpushed commits)" default=""

set -euo pipefail

root="$(git rev-parse --show-toplevel)"
# shellcheck source=../_lib/unpushed-range.sh
source "${root}/mise-tasks/_lib/unpushed-range.sh"
# shellcheck source=../_lib/our-commits.sh
source "${root}/mise-tasks/_lib/our-commits.sh"

allowlist="${root}/config/commit-email-allowlist"
[[ -f "$allowlist" ]] || { echo "identity:check: missing $allowlist" >&2; exit 2; }

patterns=()
while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line%%#*}"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  [[ -z "$line" ]] && continue
  patterns+=("$line")
done <"$allowlist"
[[ ${#patterns[@]} -gt 0 ]] || { echo "identity:check: empty allowlist" >&2; exit 2; }

email_ok() {
  local email="$1" p
  for p in "${patterns[@]}"; do
    # shellcheck disable=SC2053
    [[ "$email" =~ $p ]] && return 0
  done
  return 1
}

# mise sets usage_range; CI/local can pass $1 or IDENTITY_RANGE.
range="${usage_range:-${1:-${IDENTITY_RANGE:-}}}"
if [[ -z "$range" ]]; then
  unpushed_range
  range="$UNPUSHED_RANGE"
fi

if ! git rev-list --count "$range" >/dev/null 2>&1; then
  echo "identity:check: invalid range: $range" >&2
  exit 2
fi

load_our_email_patterns

total=$(git rev-list --count "$range")
mapfile -t ours < <(for_our_commits "$range")
count=${#ours[@]}

if [[ "$total" -eq 0 ]]; then
  echo "identity:check: nothing to check ($range)"
  exit 0
fi

if [[ "$count" -eq 0 ]]; then
  echo "identity:check: ok (0 our commits of $total in $range; skipped third-party/upstream)"
  exit 0
fi

bad=0
for sha in "${ours[@]}"; do
  author=$(git log -1 --format='%ae' "$sha")
  committer=$(git log -1 --format='%ce' "$sha")
  ok=1
  email_ok "$author" || { echo "FAIL $sha author=$author" >&2; ok=0; }
  email_ok "$committer" || { echo "FAIL $sha committer=$committer" >&2; ok=0; }
  [[ "$ok" -eq 0 ]] && bad=$((bad + 1))
done

if [[ "$bad" -gt 0 ]]; then
  echo "identity:check: $bad commit(s) outside allowlist ($count our / $total in $range)" >&2
  echo "See config/commit-email-allowlist (only commits matching config/our-commit-emails are checked)" >&2
  exit 1
fi

echo "identity:check: ok ($count our / $total in $range)"
