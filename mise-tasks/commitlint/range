#!/usr/bin/env bash
#MISE description="Validate Conventional Commit subjects for commits in a range"
#USAGE arg "[range]" help="git range (default: unpushed commits)" default=""

set -euo pipefail

root="$(git rev-parse --show-toplevel)"
# shellcheck source=../_lib/unpushed-range.sh
source "${root}/mise-tasks/_lib/unpushed-range.sh"
# shellcheck source=../_lib/commit-subject.sh
source "${root}/mise-tasks/_lib/commit-subject.sh"
# shellcheck source=../_lib/policy-range.sh
source "${root}/mise-tasks/_lib/policy-range.sh"

# mise sets usage_range; CI/local can pass $1 or COMMITLINT_RANGE.
range="${usage_range:-${1:-${COMMITLINT_RANGE:-}}}"
if [[ -z "$range" ]]; then
  unpushed_range
  range="$UNPUSHED_RANGE"
fi

if ! git rev-list --count "$range" >/dev/null 2>&1; then
  echo "commitlint:range: invalid range: $range" >&2
  exit 2
fi

total=$(git rev-list --count "$range")
if [[ "$total" -eq 0 ]]; then
  echo "commitlint:range: nothing to check ($range)"
  exit 0
fi

mapfile -t to_check < <(policy_commits_to_check "$range")
count=${#to_check[@]}
# mapfile on empty input can yield one empty element
if [[ "$count" -eq 1 && -z "${to_check[0]:-}" ]]; then
  to_check=()
  count=0
fi

skipped=$((total - count))

if [[ "$count" -eq 0 ]]; then
  echo "commitlint:range: ok (0 checked / $total in $range; skipped_upstream=${skipped})"
  exit 0
fi

bad=0
for sha in "${to_check[@]}"; do
  subject=$(git log -1 --format='%s' "$sha")
  validate_subject "$subject" "$sha" || bad=$((bad + 1))
done

if [[ "$bad" -gt 0 ]]; then
  echo "commitlint:range: $bad commit(s) failed ($count checked / $total in $range)" >&2
  exit 1
fi

echo "commitlint:range: ok ($count checked / $total in $range; skipped_upstream=${skipped})"
