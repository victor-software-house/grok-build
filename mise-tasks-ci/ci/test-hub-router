#!/usr/bin/env bash
#MISE description="PR lane: clippy + tests for the fork-local hub router crate"
#MISE dir="{{ config_root }}"
#
# File task → ci:test-hub-router. Sources ci/tools in-process so PROTOC is
# set (mise depends does not pass env to dependents).

set -euo pipefail

# shellcheck source=tools
source "$(dirname "$0")/tools"
cargo clippy --locked -p xai-computer-hub-router --all-targets -- -D warnings
cargo test --locked -p xai-computer-hub-router
